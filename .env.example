# 📝 EXEMPLE DE FICHIER .env

# Django
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=plateforme_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=127.0.0.1
DB_PORT=5432

# Production security
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
USE_X_FORWARDED_PROTO=False

# MonCash Configuration (à remplir après création du compte)
MONCASH_API_KEY=your_api_key_here
MONCASH_SECRET_KEY=your_secret_key_here
MONCASH_ENVIRONMENT=sandbox  # sandbox ou production
MONCASH_CALLBACK_URL=https://votredomaine.com/api/paiement/webhook/

# Email (optionnel, pour les notifications)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-password-here

# Application
SITE_NAME=Plateforme Concours
SITE_URL=http://localhost:8000
 
# Exemple production
# DEBUG=False
# ALLOWED_HOSTS=monsite.com,www.monsite.com
# CSRF_TRUSTED_ORIGINS=https://monsite.com,https://www.monsite.com
